rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny all access
    match /{document=**} {
      allow read, write: if false;
    }

    // Users can only read and write their own preferences
    match /user_preferences/{userId} {
      allow read, write, update, delete: if request.auth.uid == userId;
    }

    // Users can manage their own FCM token
    match /user_fcm_tokens/{userId} {
      allow read, write, update, delete: if request.auth.uid == userId;
    }

    // Users can read, write, and delete their own data and any subcollections
    match /users/{userId} {
      allow read, write, update, delete: if request.auth.uid == userId;
      
      match /{document=**} {
        allow read, write, update, delete: if request.auth.uid == userId;
      }
    }

    // Felt reports are write-only for authenticated users
    match /felt_reports/{reportId} {
      allow create: if request.auth != null;
      allow read, delete: if resource.data.userId == request.auth.uid;
      allow update: if false;
    }

    // Metadata is read-only for authenticated users.
    match /metadata/{doc} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Earthquakes are read-only for authenticated users.
    match /earthquakes/{earthquakeId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Community seismograph readings
    match /community_readings/{readingId} {
      // Users can create readings if authenticated and their userId matches
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      // Users can read their own readings
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    // Community detected alerts (generated by backend)
    match /community_alerts/{alertId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Safety Circles
    match /circles/{circleId} {
      // Authenticated users can create circles
      allow create: if request.auth != null;
      // Members of the circle can read its data
      allow read: if request.auth != null && request.auth.uid in resource.data.memberIds;
      // Members can update if they are just updating their own status 
      // OR owners can update anything. (Simplified for now)
      allow update: if request.auth != null && request.auth.uid in resource.data.memberIds;
      // Only owners can delete
      allow delete: if request.auth != null && request.auth.uid == resource.data.ownerId;
    }

    // Device accounts collection for one-user-per-device enforcement
    match /device_accounts/{deviceId} {
      // Allow unauthenticated reads so the app can check if a device is 
      // already linked BEFORE account creation.
      allow read: if true;
      // Allow creation, update, and deletion.
      allow create, update, delete: if true;
    }
  }
}
